{
  "name": "@autodev/codebase",
  "version": "0.0.6",
  "type": "module",
  "bin": {
    "codebase": "./dist/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "npx tsx src/cli.ts --demo",
    "build": "rollup -c rollup.config.cjs && chmod +x dist/cli.js",
    "type-check": "npx tsc -p tsconfig.json --noEmit",
    "mcp-server": "npx tsx src/cli.ts --serve --demo --port=3001",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx vitest --config vitest.e2e.config.ts",
    "test:coverage": "vitest run --coverage",
    "push": "npm publish --access public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.1",
    "@qdrant/js-client-rest": "^1.11.0",
    "async-mutex": "^0.5.0",
    "csstype": "^3.1.3",
    "form-data": "^4.0.3",
    "fzf": "^0.5.2",
    "ignore": "^5.3.1",
    "jsonc-parser": "^3.3.1",
    "lodash.debounce": "^4.0.8",
    "openai": "^4.52.0",
    "p-limit": "^3.1.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-wasms": "^0.1.12",
    "tslib": "^2.7.0",
    "undici": "^6.19.8",
    "undici-types": "^7.10.0",
    "uuid": "^10.0.0",
    "vitest": "^3.2.4",
    "web-tree-sitter": "^0.23.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/express": "^5.0.3",
    "@types/lodash.debounce": "^4.0.9",
    "@types/uuid": "^10.0.0",
    "rollup": "^4.21.2",
    "tsx": "^4.20.3",
    "typescript": "^5.6.2"
  }
}
